---
import Layout from "./layout.astro";
import Link from "../components/link.astro";
---

<Layout {...Astro.props}>
  <header class="p-8">
    <nav
      class="flex flex-col items-center justify-center gap-8 lg:flex-row lg:gap-20"
    >
      <a href="/" class="font-title text-sm text-lime-400 md:text-2xl">
        {/* TODO Better way to do this? br and nbsps feels hacky */}
        NBA&nbsp;Surprise<br />Teams&nbsp;Tracker
      </a>
      <div class="flex flex-row gap-8">
        <Link class="text-xl md:text-2xl" href="/info">What is this?</Link>
        <Link class="text-xl md:text-2xl" href="/archive">Archive</Link>
      </div>
    </nav>
  </header>
  <main class="space-y-12 pb-16">
    <slot />
  </main>
</Layout>
